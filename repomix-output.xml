                      </span>
                    )}
                  </div>
                  {unreadCount > 0 && (
                    <button type="button" onClick={markAllNotifsRead} className="text-[10px] font-medium text-accent-600 hover:underline">
                      모두 읽음
                    </button>
                  )}
