      if (isSupplierRole(res.role)) {
        router.push(res.onboardingComplete === false ? '/supplier/onboarding' : '/supplier');
      } else {
        router.push('/dashboard');
      }
    } catch (err) {
      setError(
        err instanceof ApiError && err.status === 401
