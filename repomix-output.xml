  };
}

function isImageFile(doc: ParsedDoc): boolean {
  const source = `${doc.fileUrl ?? doc.fileName}`.toLowerCase();
  return source.startsWith('data:image/') || /\.(png|jpe?g|webp|gif)(?:[?#].*)?$/.test(source);
}

