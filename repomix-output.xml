                        <button
                          type="button"
                          onClick={() => onOpenMailFor(s.supplierId)}
                          title={mailed ? '이미 발송됨 · 다시 보내기' : `${s.companyName}에 정보 입력 요청 메일 보내기`}
                          className={`inline-flex h-8 items-center gap-1.5 rounded-sm border px-2.5 text-xs font-bold transition ${
                            mailed
