        tone === 'ok' && 'border-emerald-200 bg-emerald-50 text-emerald-700',
        tone === 'warn' && 'border-amber-200 bg-amber-50 text-amber-700',
        tone === 'alert' && 'border-red-200 bg-red-50 text-red-700',
