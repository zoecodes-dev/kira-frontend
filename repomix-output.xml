    entity_id            UUID,
    required_field_count INT,
    filled_field_count   INT,
    completion_rate      NUMERIC(5,2),
    missing_fields       JSONB,
    last_updated_by      UUID REFERENCES users(user_id),
    last_updated_at      TIMESTAMPTZ DEFAULT now()
