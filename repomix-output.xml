        <span className={clsx('inline-flex shrink-0 items-center gap-1 whitespace-nowrap rounded-full border px-2 py-0.5 text-xs font-bold', status.badge)}>
          <StatusIcon className="h-3 w-3 shrink-0" />
          {status.label}
