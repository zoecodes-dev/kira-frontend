  // ── 작업7-2. certifications 오버라이드 — 만료 임박 인증서 강제 삽입 ──
  const certifications = (() => {
    const raw = getCertifications(supplierId) ?? [];
    const injected = [
      // 기존 인증서 유지
      ...raw,
      // 만료 임박 인증서 추가 (대시보드 리스크 카드 활성화용)
