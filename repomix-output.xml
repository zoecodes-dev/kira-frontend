<file path="supply-chain-map-mockup.html">
<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>제품 BOM 기반 공급망 추적 목업</title>
  <style>
    :root {
      --bg: #f5f7fb;
      --panel: #ffffff;
      --panel-soft: #f8fafc;
      --line: #d9e2ef;
      --line-soft: #edf2f7;
      --text: #182235;
      --muted: #64748b;
      --blue: #2563eb;
      --blue-soft: #eff6ff;
      --green: #059669;
      --green-soft: #ecfdf5;
      --amber: #d97706;
      --amber-soft: #fffbeb;
      --red: #dc2626;
      --red-soft: #fef2f2;
      --violet: #6d28d9;
      --violet-soft: #f5f3ff;
      --shadow: 0 14px 34px rgba(15, 23, 42, 0.06);
      --radius: 12px;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      background: var(--bg);
      color: var(--text);
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Noto Sans KR", Arial, sans-serif;
      font-size: 14px;
      letter-spacing: 0;
    }

    button,
    input,
    select {
      font: inherit;
    }

    .page {
      max-width: 1480px;
      margin: 0 auto;
      padding: 24px;
    }

    .top {
      display: flex;
      justify-content: space-between;
      gap: 18px;
      align-items: flex-start;
      margin-bottom: 18px;
    }

    .eyebrow {
      color: var(--blue);
      font-size: 12px;
      font-weight: 800;
      margin-bottom: 6px;
    }

    h1 {
      margin: 0;
      font-size: 25px;
      line-height: 1.2;
    }

    .desc {
      max-width: 860px;
      margin: 8px 0 0;
      color: var(--muted);
      line-height: 1.55;
      font-size: 13px;
    }

    .actions {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    .btn {
      height: 38px;
      border: 1px solid var(--line);
      border-radius: 9px;
      background: var(--panel);
      color: var(--text);
      padding: 0 13px;
      font-size: 13px;
      font-weight: 750;
      cursor: pointer;
      white-space: nowrap;
    }

    .btn.primary {
      background: var(--blue);
      border-color: var(--blue);
      color: #fff;
    }

    .filters {
      display: grid;
      grid-template-columns: 1.4fr 0.8fr 0.95fr 0.8fr 0.7fr 0.85fr auto;
      gap: 10px;
      padding: 14px;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: var(--panel);
      box-shadow: var(--shadow);
      margin-bottom: 14px;
    }

    .field label {
      display: block;
      margin-bottom: 6px;
      color: var(--muted);
      font-size: 11px;
      font-weight: 850;
    }

    .field select,
    .field input {
      width: 100%;
      height: 40px;
      border: 1px solid var(--line);
      border-radius: 9px;
      background: #fff;
      color: var(--text);
      padding: 0 11px;
      font-size: 13px;
      font-weight: 650;
    }

    .filter-action {
      align-self: end;
    }

    .filter-action .btn {
      width: 100%;
      min-width: 118px;
      height: 40px;
    }

    .metrics {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 12px;
      margin-bottom: 16px;
    }

    .metric {
      padding: 15px;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: var(--panel);
      box-shadow: var(--shadow);
    }

    .metric .label {
      color: var(--muted);
      font-size: 12px;
      font-weight: 750;
    }

    .metric .value {
      margin-top: 6px;
      font-size: 25px;
      font-weight: 900;
    }

    .metric .hint {
      margin-top: 4px;
      color: var(--muted);
      font-size: 12px;
    }

    .layout {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 400px;
      gap: 16px;
      align-items: start;
    }

    .panel {
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: var(--panel);
      box-shadow: var(--shadow);
      overflow: hidden;
    }

    .panel-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 15px 17px;
      border-bottom: 1px solid var(--line-soft);
      background: #fbfdff;
    }

    .panel-title {
      font-size: 16px;
      font-weight: 850;
    }

    .panel-sub {
      margin-top: 3px;
      color: var(--muted);
      font-size: 12px;
      line-height: 1.45;
    }

    .mode {
      display: flex;
      gap: 6px;
      padding: 4px;
      border: 1px solid var(--line);
      border-radius: 999px;
      background: #fff;
    }

    .mode button {
      border: 0;
      border-radius: 999px;
      background: transparent;
      color: var(--muted);
      padding: 7px 11px;
      font-size: 12px;
      font-weight: 800;
      cursor: pointer;
    }

    .mode button.active {
      background: var(--blue-soft);
      color: var(--blue);
    }

    .lineage {
      padding: 16px 18px 18px;
    }

    .stage {
      display: grid;
      grid-template-columns: 126px minmax(0, 1fr);
      gap: 12px;
      margin-bottom: 14px;
    }

    .stage:last-child {
      margin-bottom: 0;
    }

    .stage-label {
      padding-top: 14px;
      color: #334155;
      font-size: 12px;
      font-weight: 900;
    }

    .stage-box {
      border: 1px solid var(--line);
      border-radius: 12px;
      background: #fff;
      overflow: hidden;
    }

    .stage-box.product {
      border-color: #bfdbfe;
      background: var(--blue-soft);
    }

    .node {
      position: relative;
      display: grid;
      grid-template-columns: minmax(230px, 1.6fr) 98px 128px 86px 110px;
      gap: 10px;
      align-items: center;
      min-height: 62px;
      padding: 12px 14px;
      border-top: 1px solid var(--line-soft);
    }

    .node:first-child {
      border-top: 0;
    }

    .node.group {
      background: #fbfdff;
    }

    .node-title {
      font-weight: 850;
    }

    .node-meta {
      margin-top: 3px;
      color: var(--muted);
      font-size: 12px;
      line-height: 1.4;
    }

    .indent-1 {
      padding-left: 34px;
    }

    .indent-2 {
      padding-left: 58px;
    }

    .indent-3 {
      padding-left: 82px;
    }

    .indent-1::before,
    .indent-2::before,
    .indent-3::before {
      content: "";
      position: absolute;
      top: 0;
      bottom: 0;
      width: 1px;
      background: var(--line);
    }

    .indent-1::before {
      left: 18px;
    }

    .indent-2::before {
      left: 42px;
    }

    .indent-3::before {
      left: 66px;
    }

    .branch {
      position: absolute;
      top: 30px;
      width: 18px;
      border-top: 1px solid var(--line);
    }

    .indent-1 .branch {
      left: 18px;
    }

    .indent-2 .branch {
      left: 42px;
    }

    .indent-3 .branch {
      left: 66px;
    }

    .pill {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 26px;
      border: 1px solid transparent;
      border-radius: 999px;
      padding: 5px 9px;
      font-size: 11px;
      font-weight: 850;
      white-space: nowrap;
    }

    .blue {
      background: var(--blue-soft);
      border-color: #bfdbfe;
      color: var(--blue);
    }

    .green {
      background: var(--green-soft);
      border-color: #bbf7d0;
      color: var(--green);
    }

    .amber {
      background: var(--amber-soft);
      border-color: #fde68a;
      color: var(--amber);
    }

    .red {
      background: var(--red-soft);
      border-color: #fecaca;
      color: var(--red);
    }

    .violet {
      background: var(--violet-soft);
      border-color: #ddd6fe;
      color: var(--violet);
    }

    .slate {
      background: var(--panel-soft);
      border-color: var(--line);
      color: #334155;
    }

    .legend {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      padding: 0 18px 16px;
    }

    .side {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .summary {
      padding: 15px;
    }

    .summary-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
    }

    .mini {
      min-height: 70px;
      border: 1px solid var(--line);
      border-radius: 10px;
      background: #fff;
      padding: 11px;
    }

    .mini .k {
      color: var(--muted);
      font-size: 11px;
      font-weight: 800;
    }

    .mini .v {
      margin-top: 6px;
      font-weight: 850;
      line-height: 1.35;
    }

    .checklist {
      padding: 4px 15px 15px;
    }

    .check-item {
      display: flex;
      gap: 9px;
      padding: 10px 0;
      border-bottom: 1px solid var(--line-soft);
    }

    .check-item:last-child {
      border-bottom: 0;
    }

    .check-dot {
      flex: 0 0 auto;
      width: 22px;
      height: 22px;
      border-radius: 999px;
      background: var(--green-soft);
      color: var(--green);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 12px;
      font-weight: 900;
    }

    .check-dot.warn {
      background: var(--amber-soft);
      color: var(--amber);
    }

    .check-title {
      font-size: 13px;
      font-weight: 850;
    }

    .check-txt {
      margin-top: 3px;
      color: var(--muted);
      font-size: 12px;
      line-height: 1.45;
    }

    .notice {
      padding: 13px 15px;
      border-top: 1px solid #fed7aa;
      background: #fff7ed;
      color: #9a3412;
      font-size: 12px;
      line-height: 1.5;
    }

    .section-gap {
      margin-top: 16px;
    }

    .table-wrap {
      overflow: auto;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 13px;
    }

    th {
      padding: 11px;
      border-bottom: 1px solid var(--line);
      background: var(--panel-soft);
      color: #475569;
      text-align: left;
      font-size: 11px;
      font-weight: 850;
      white-space: nowrap;
    }

    td {
      padding: 12px 11px;
      border-bottom: 1px solid var(--line-soft);
      white-space: nowrap;
    }

    td:first-child {
      font-weight: 850;
    }

    .mobile-note {
      display: none;
      margin: 14px 18px 0;
      border: 1px solid var(--line);
      border-radius: 10px;
      background: #fff;
      color: var(--muted);
      padding: 11px;
      font-size: 12px;
      line-height: 1.45;
    }

    @media (max-width: 1180px) {
      .filters {
        grid-template-columns: repeat(3, 1fr);
      }

      .metrics {
        grid-template-columns: repeat(3, 1fr);
      }

      .layout {
        grid-template-columns: 1fr;
      }

      .side {
        display: grid;
        grid-template-columns: 1fr 1fr;
      }
    }

    @media (max-width: 760px) {
      .page {
        padding: 14px;
      }

      .top {
        display: block;
      }

      .actions {
        justify-content: flex-start;
        margin-top: 12px;
      }

      .filters,
      .metrics,
      .side,
      .summary-grid {
        grid-template-columns: 1fr;
      }

      .panel-head {
        align-items: flex-start;
        flex-direction: column;
      }

      .mode {
        max-width: 100%;
        overflow: auto;
      }

      .stage {
        grid-template-columns: 1fr;
        gap: 6px;
      }

      .stage-label {
        padding-top: 0;
      }

      .stage-box {
        overflow: auto;
      }

      .node {
        min-width: 760px;
      }

      .mobile-note {
        display: block;
      }
    }
  </style>
</head>
<body>
  <main class="page">
    <header class="top">
      <div>
        <div class="eyebrow">PRODUCT TRACEABILITY / BOM BASED SUPPLY CHAIN</div>
        <h1>제품 BOM 기반 공급망 추적</h1>
        <p class="desc">
          제품과 단위기간을 먼저 선택하면 BOM 항목을 기준으로 원재료, 조달 정보, 협력사, 사업장, PO가 연결됩니다.
          운영자는 누락 데이터를 관리하고, 고객사와 감사기관은 같은 결과를 규제 확인용 증빙으로 조회할 수 있습니다.
        </p>
      </div>
      <div class="actions" aria-label="내보내기">
        <button class="btn">CSV 다운로드</button>
        <button class="btn primary">Excel 다운로드</button>
      </div>
    </header>

    <section class="filters" aria-label="공급망 추적 조건">
      <div class="field">
        <label for="product">제품</label>
        <select id="product">
          <option>EV-BATTERY-PACK-77kWh / KIRA Battery Pack</option>
          <option>EV-MOTOR-DRIVE-220kW / KIRA Motor Drive</option>
        </select>
      </div>
      <div class="field">
        <label for="bom">BOM 버전</label>
        <select id="bom">
          <option>v3.2 / active</option>
          <option>v3.1 / archived</option>
        </select>
      </div>
      <div class="field">
        <label for="period">단위기간</label>
        <input id="period" value="2026-05-01 ~ 2026-05-31" />
      </div>
      <div class="field">
        <label for="site">사업장</label>
        <select id="site">
          <option>전체 사업장</option>
          <option>울산 배터리 조립공장</option>
          <option>광양 소재공장</option>
        </select>
      </div>
      <div class="field">
        <label for="region">목적지</label>
        <select id="region">
          <option>EU</option>
          <option>US</option>
          <option>KR</option>
        </select>
      </div>
      <div class="field">
        <label for="po">PO</label>
        <input id="po" value="전체 PO" />
      </div>
      <div class="filter-action">
        <button class="btn primary">맵 생성</button>
      </div>
    </section>

    <section class="metrics" aria-label="추적 요약 지표">
      <div class="metric">
        <div class="label">BOM 항목</div>
        <div class="value">14</div>
        <div class="hint">부품 및 원재료 포함</div>
      </div>
      <div class="metric">
        <div class="label">연결 협력사</div>
        <div class="value">9</div>
        <div class="hint">Tier 1부터 Tier 4까지</div>
      </div>
      <div class="metric">
        <div class="label">고위험 노드</div>
        <div class="value" style="color: var(--red);">2</div>
        <div class="hint">FEOC 및 인권 실사 대상</div>
      </div>
      <div class="metric">
        <div class="label">데이터 정합률</div>
        <div class="value" style="color: var(--green);">87%</div>
        <div class="hint">검증 완료 기준</div>
      </div>
      <div class="metric">
        <div class="label">미응답 협력사</div>
        <div class="value" style="color: var(--amber);">3</div>
        <div class="hint">초대 또는 재요청 필요</div>
      </div>
    </section>

    <div class="layout">
      <section class="panel">
        <div class="panel-head">
          <div>
            <div class="panel-title">공급망 맵</div>
            <div class="panel-sub">제품 BOM을 기준으로 하위 재료와 조달처를 일방향으로 추적합니다.</div>
          </div>
          <div class="mode" aria-label="보기 모드">
            <button class="active">운영자</button>
            <button>감사용</button>
            <button>테이블</button>
          </div>
        </div>
        <div class="mobile-note">모바일에서는 가로로 스크롤해 제품, BOM, 협력사, 사업장, 리스크를 확인합니다.</div>

        <div class="lineage">
          <div class="stage">
            <div class="stage-label">0. 제품</div>
            <div class="stage-box product">
              <div class="node">
                <div>
                  <div class="node-title">KIRA Battery Pack 77kWh</div>
                  <div class="node-meta">제품 코드 EV-BAT-77 / 제조사 KIRA Mobility</div>
                </div>
                <span class="pill blue">제품</span>
                <span>완제품</span>
                <span>KR</span>
                <span class="pill green">정상</span>
              </div>
            </div>
          </div>

          <div class="stage">
            <div class="stage-label">1. BOM 부품</div>
            <div class="stage-box">
              <div class="node group">
                <div>
                  <div class="node-title">Battery Cell Module</div>
                  <div class="node-meta">BOM item / 48 EA / 제품 중량 42.5%</div>
                </div>
                <span class="pill slate">Tier 1</span>
                <span>Cell System</span>
                <span>KR</span>
                <span class="pill green">정상</span>
              </div>
              <div class="node group">
                <div>
                  <div class="node-title">Cathode Active Material</div>
                  <div class="node-meta">BOM item / 128.5 kg / 제품 중량 31.2%</div>
                </div>
                <span class="pill slate">Tier 1</span>
                <span>양극재</span>
                <span>CN</span>
                <span class="pill amber">주의</span>
              </div>
              <div class="node group">
                <div>
                  <div class="node-title">Anode Material</div>
                  <div class="node-meta">BOM item / 82.0 kg / 제품 중량 18.6%</div>
                </div>
                <span class="pill slate">Tier 1</span>
                <span>음극재</span>
                <span>KR</span>
                <span class="pill green">정상</span>
              </div>
            </div>
          </div>

          <div class="stage">
            <div class="stage-label">2. 원재료/광물</div>
            <div class="stage-box">
              <div class="node indent-1">
                <span class="branch"></span>
                <div>
                  <div class="node-title">Lithium Hydroxide</div>
                  <div class="node-meta">양극재 하위 원재료 / 광물 비율 8.4%</div>
                </div>
                <span class="pill slate">Tier 2</span>
                <span>LiOH</span>
                <span>AU</span>
                <span class="pill green">정상</span>
              </div>
              <div class="node indent-1">
                <span class="branch"></span>
                <div>
                  <div class="node-title">Cobalt Sulfate</div>
                  <div class="node-meta">양극재 하위 원재료 / 광물 비율 12.8%</div>
                </div>
                <span class="pill slate">Tier 2</span>
                <span>CoSO4</span>
                <span>CD</span>
                <span class="pill red">고위험</span>
              </div>
              <div class="node indent-1">
                <span class="branch"></span>
                <div>
                  <div class="node-title">Nickel Sulfate</div>
                  <div class="node-meta">양극재 하위 원재료 / 광물 비율 21.6%</div>
                </div>
                <span class="pill slate">Tier 2</span>
                <span>NiSO4</span>
                <span>ID</span>
                <span class="pill amber">주의</span>
              </div>
            </div>
          </div>

          <div class="stage">
            <div class="stage-label">3. 공급사/사업장</div>
            <div class="stage-box">
              <div class="node indent-2">
                <span class="branch"></span>
                <div>
                  <div class="node-title">Ganzhou Refinery</div>
                  <div class="node-meta">PO-2026-0512 / Ganzhou Processing Plant / 공급 비율 64%</div>
                </div>
                <span class="pill slate">Tier 3</span>
                <span>정련소</span>
                <span>CN</span>
                <span class="pill red">FEOC 검토</span>
              </div>
              <div class="node indent-2">
                <span class="branch"></span>
                <div>
                  <div class="node-title">Katanga Mining</div>
                  <div class="node-meta">PO-2026-0503 / Katanga Site Refinery / 공급 비율 36%</div>
                </div>
                <span class="pill slate">Tier 4</span>
                <span>광산</span>
                <span>CD</span>
                <span class="pill red">실사 필요</span>
              </div>
              <div class="node indent-2">
                <span class="branch"></span>
                <div>
