export const INVITE_MAIL_SUBJECT = 'KIRA ESG 관리 시스템 — 공급망 정보 입력 요청';

export function buildInviteMailBody(companyName: string, supplierId?: string): string {
  // 초대 링크는 supplierId 쿼리로 키잉(무토큰, decision #8) — 가입 화면이 이 id로
